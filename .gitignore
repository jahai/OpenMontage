# Python
__pycache__/
*.pyc
*.pyo
*.egg-info/
dist/
build/

# Test/IDE
.pytest_cache/
.mypy_cache/
.ruff_cache/
htmlcov/
.coverage
.trae/
.idea/
.vscode/

# Pipeline outputs (regenerable — never commit large media)
output/
pipeline/
tests/qa/output/

# Project workspaces (generated assets, renders — all regenerable).
# Use projects/* (not projects/) so Git can recurse and apply the
# Latent Systems carve-outs below.
projects/*

# --- Latent Systems carve-outs (Phase 1 Day 10 / Day 5-9 review §2-A) ---
# Latent Systems structural content is git-tracked. Generated assets
# (PNGs, MP4s, MP3s, WAVs, JPGs) under ep1/ and shared/ stay ignored;
# structural docs (NOTES.md, README.md, *.md docs, source code, config)
# get carved back in. Activates AD-5 hook enforcement on real commits
# and makes spec §5 backup-via-git story factually correct.
!projects/latent_systems/
projects/latent_systems/*
!projects/latent_systems/PROJECT_ARCHITECTURE.md
!projects/latent_systems/NOTES.md
!projects/latent_systems/docs/
!projects/latent_systems/tools/
!projects/latent_systems/tool_build/
!projects/latent_systems/ep1/
!projects/latent_systems/shared/

# Inside ep1/ and shared/, default-ignore everything; whitelist NOTES.md
# + README.md + structural-doc *.md anywhere in the subtree.
projects/latent_systems/ep1/**
!projects/latent_systems/ep1/**/
!projects/latent_systems/ep1/**/NOTES.md
!projects/latent_systems/ep1/**/README.md
projects/latent_systems/shared/**
!projects/latent_systems/shared/**/
!projects/latent_systems/shared/**/NOTES.md
!projects/latent_systems/shared/**/README.md

# Re-ignore tool_build/_data runtime files (state.db cache + operational JSON/log).
# Per AD-5, state.db is cache; canonical YAMLs at _data/<artifact_type>/*.yaml
# stay tracked as source of truth.
projects/latent_systems/tool_build/_data/state.db
projects/latent_systems/tool_build/_data/state.db-*
projects/latent_systems/tool_build/_data/_*.json
projects/latent_systems/tool_build/_data/_*.txt
projects/latent_systems/tool_build/_data/_*.log
projects/latent_systems/tool_build/_data/_*.tmp
projects/latent_systems/tool_build/_data/_server.shutdown
# Phase 2 Wave A audit thumbnail cache (regenerable via
# thumbnails.get_or_generate; never source-of-truth)
projects/latent_systems/tool_build/_data/_audit_thumbnails/
# Test scratch dirs (created by test_thumbnails.py and similar)
projects/latent_systems/tool_build/_data/_test_*/
# But keep the _inbox_review tooling tracked (operational scripts + ledger
# = audit trail of stray-routing decisions):
!projects/latent_systems/tool_build/_data/_inbox_review/
!projects/latent_systems/tool_build/_data/_inbox_review/**

# Corpus directories (downloaded stock clips, thumbnails, embeddings —
# regenerable from source APIs via corpus_builder). Explicit rule even
# though most corpora live under projects/ since agents sometimes
# build scratch corpora at the repo root.
corpus/
**/corpus/

# User music library (personal royalty-free tracks — not part of repo)
music_library/

# Environment & credentials
.env
.env.local
*.env
.youtube-token.json

# Stray media downloads (test/scratch clips left in repo root)
pexels_video_*.mp4

# Scratch/debug scripts
scratch/

# Internal docs (strategy, handoffs, playbooks — not shipped)
internal/

# Local agent config (user-specific)
.claude/memory/
.claude/settings.local.json

# Agent skills lock (local install tracking)
skills-lock.json

# Generated images (logo drafts — final logo lives in assets/)
logo_*.png
generated_image.png

# Downloaded music files (Pixabay, Freesound — not source code)
pixabay_music_*

# OS
.DS_Store
Thumbs.db

# Node (for remotion-composer/)
node_modules/

# Remotion build output and copied project assets (regenerable at render time)
remotion-composer/out/
remotion-composer/public/*
# But keep demo props (shipped with the project for zero-key demos)
!remotion-composer/public/demo-props/
# Ignore test/scratch compositions in demo-props (keep only curated demos)
remotion-composer/public/demo-props/test-*
remotion-composer/public/demo-props/talking-head-*
remotion-composer/public/demo-props/caption-burn-*
